# .env.example
# Copy this file to .env for local development.
# Never commit a .env file with real secrets.

# ── Database ──
# Local development (Docker Compose PostgreSQL):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dten_weekly_execution?schema=public"
# Production: provided by the service/infrastructure team
# DATABASE_URL="postgresql://<user>:<password>@<host>:<port>/<database>?schema=public"

# ── Authentication ──
# Generate a secure secret for production: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# ── Email notifications ──
# Supported values: dev-log (console only), disabled
EMAIL_PROVIDER="dev-log"
EMAIL_FROM="DTEN OKR System <no-reply@dten.local>"

# ── Application URL ──
# Used in email links and OAuth redirects
APP_BASE_URL="http://localhost:3000"

# ── Runtime (optional) ──
# PORT defaults to 3000 if not set
# PORT=3000
# NODE_ENV is set to "production" inside the Docker image automatically
# NODE_ENV=production
