# Local PostgreSQL connection for Prisma.
# Replace user/password/database with your local values when you are ready to run migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dten_weekly_execution?schema=public"

# Used later by NextAuth/Auth.js.
AUTH_SECRET="replace-with-a-long-random-secret"

# Email notifications default to local logging for development.
# Supported values: dev-log, disabled
EMAIL_PROVIDER="dev-log"
EMAIL_FROM="DTEN OKR System <no-reply@dten.local>"
APP_BASE_URL="http://localhost:3000"
